# Trading Prediction API - Environment Variables
# ===============================================
# Copy this file to .env and customize values

# Flask Configuration
FLASK_ENV=development  # development, production, testing
SECRET_KEY=your-secret-key-change-in-production

# API Security
API_KEY_REQUIRED=false  # Set to true in production
API_KEYS=key1,key2,key3  # Comma-separated list of valid API keys

# Redis Configuration (for rate limiting in production)
REDIS_URL=redis://localhost:6379/0
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# Model Paths
MODEL_DIR=../models

# Database (optional - for time series storage)
TIMESERIES_DB_HOST=localhost
TIMESERIES_DB_PORT=5432
TIMESERIES_DB_NAME=trading_data
TIMESERIES_DB_USER=trading
TIMESERIES_DB_PASSWORD=change-me

# Gunicorn (production)
GUNICORN_BIND=0.0.0.0:5000
GUNICORN_WORKERS=4
GUNICORN_LOG_LEVEL=info

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
